      // Function to check if a URL contains #cover
      function containsCover(url) {
        return url.includes("#cover");
      }

      // Function to check if a URL contains /blogs/feed
      function containsFeed(url) {
        return url.includes("/blogs/feed");
      }

      // Function to reload the page with #cover
      function reloadWithCover() {
        window.location.reload();
      }

      // Function to clear the memory of reloading
      function clearReloadMemory() {
        hasCover = false;
        hasFeed = false;
      }

      // Check for changes in the URL
      setInterval(() => {
        const currentURL = window.location.href;

        if (containsCover(currentURL)) {
          hasCover = true;
        } else if (containsFeed(currentURL)) {
          hasFeed = true;
        }

        if (hasCover && hasFeed) {
          reloadWithCover();
          clearReloadMemory();
        }
      
        lastURL = currentURL;
      }, 1000); // Check every 1 second (adjust the interval as needed)

   
